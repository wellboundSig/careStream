  has_homecare_services checkbox
  homecare_agency_name string
  homecare_hours       string
  homecare_days        string
  has_community_hab    checkbox
  services_needed      multiselect [note: 'SN, PT, ST, OT']
  therapy_availability string
  is_diabetic          checkbox
  diabetes_monitor_by  string
  pcp_name             string
  pcp_last_visit       dateTime
  pcp_phone            string
  pcp_fax              string
  pcp_address          string
  cm_name              string
  cm_company           string
  cm_phone             string
  cm_fax_or_email      string
  created_at           dateTime
  updated_at           dateTime
}

Table TriagePediatric {
  id                        string    [pk]
  referral_id               string    [ref: > Referrals.id, not null, note: 'unique']
  filled_by_id              string    [ref: > Users.id, not null]
  phone_call_made_to        string
  household_description     string
  has_pets                  checkbox
  pet_details               string
  has_homecare_services     checkbox
  homecare_agency_name      string
  homecare_hours            string
  homecare_days             string
  boe_services              string
  has_community_hab         checkbox
  services_needed           multiselect [note: 'SN, PT, ST, OT, ABA']
  therapy_availability      string
  hha_hours_frequency       string
  is_diabetic               checkbox
  diabetes_monitor_by       string
  immunizations_up_to_date  string
  school_bus_time           string
  recent_hospitalization    string
  pcp_name                  string
  pcp_last_visit            dateTime
  pcp_phone                 string
  pcp_fax                   string
  pcp_address               string
  cm_name                   string
  cm_company                string
  cm_phone                  string
  potential_soc_date        dateTime
