Table TriageALF {
  Name        string    [pk]
  Notes       text
  Assignee    collaborator
  Status      enum      [note: 'Todo, In progress, Done']
  Attachments attachment
  Attachment_Summary aiText
}

// ─── Directory: People & Places ─────────────────────────────────────────────

Table Marketers {
  id                    string    [pk]
  user_id               string    [ref: > Users.id]
  first_name            string    [not null]
  last_name             string    [not null]
  email                 string    [not null]
  phone                 string
  region                multiselect [note: 'Regional, Bronx, Pelham, Putnam, Queens, Westchester']
  division              string    [note: 'ALF, Special Needs, Both']
  status                enum      [note: 'Active']
  created_at            dateTime
  supervising_marketer  checkbox
}

Table Physicians {
  id                string    [pk]
  first_name        string    [not null]
  last_name         string    [not null]
  npi               string    [note: 'unique']
  phone             string
  fax               string
  address_street    string
  address_city      string
  address_state     enum      [note: 'NY']
  address_zip       string
  is_pecos_enrolled checkbox
  is_opra_enrolled  checkbox
  pecos_last_checked dateTime
  facility_id       string    [ref: > Facilities.id]
  is_active         string    [note: 'default true']
  created_at        dateTime
}

Table Facilities {
  id                              string    [pk]
  name                            string    [not null]
  type                            enum      [note: 'NURSING HOME, ASSISTED LIVING FACILITY, CARE COORDINATION ORG, SKILLED NURSING FACILITY, HOSPITAL, OTHER, PHARMACY, REFERRAL SOURCE, FUNERAL HOME']
  address_street                  string
  address_city                    string
  address_state                   enum      [note: 'NY']
  address_zip                     integer
  phone                           string
  fax                             string
  primary_contact_name            string
  primary_contact_phone           string
  primary_contact_email           string
  region                          enum      [note: 'Bronx, LI, Westchester, NYC, County, NASSAU, BRONX, KINGS, SUFFOLK, NEW YORK, QUEENS, WESTCHESTER, BROOME, BERGEN, RICHMOND, ROCKLAND, MONMOUTH, PUTNAM, DUTCHESS, DALLAS']
  services_provided_internally    string
  notes                           string
  is_active                       string
  created_at                      dateTime
}

Table NetworkFacilities {
  id              string    [pk]
  name            string    [not null]
  region          string
  marketer_id     string    [ref: > Marketers.id]
  case_manager    string
  type            enum      [note: 'NURSING HOME, ASSISTED LIVING FACILITY, CARE COORDINATION ORG, SKILLED NURSING FACILITY, HOSPITAL, OTHER, PHARMACY, REFERRAL SOURCE, FUNERAL HOME']
  address_street  string
  zipcode         string
}

Table ReferralSources {
  id          string    [pk]
  name        string    [not null]
  type        string    [not null]
  is_active   string    [note: 'default true']
  created_at  dateTime
  marketer_id string    [ref: > Marketers.id]
}

Table Campaigns {
  id          string    [pk]
  name        string    [not null]
  division    enum      [note: 'ALF, Special Needs']
  region      string
  start_date  dateTime
  end_date    dateTime
  status      enum      [note: 'Active']
  notes       string
  created_at  dateTime
}

// ─── Join Tables ────────────────────────────────────────────────────────────

Table MarketerFacilities {
  id            string    [pk]
  marketer_id   enum      [ref: > Marketers.id, not null]
  facility_id   string    [ref: > Facilities.id, not null]
  is_primary    checkbox
  assigned_date dateTime
}

Table CampaignMarketers {
  id          string    [pk]
  campaign_id string    [ref: > Campaigns.id, not null]
  marketer_id string    [ref: > Marketers.id, not null]
}

// ─── Users, Roles & Permissions ─────────────────────────────────────────────

Table Users {
  id              string    [pk]
  clerk_user_id   string    [not null, note: 'unique — from Clerk']
  email           string    [not null]
  first_name      string    [not null]
  last_name       string    [not null]
  role_id         string    [ref: > Roles.id, not null]
  status          enum      [note: 'Active']
  scope           enum      [note: 'DEPRECATED — DevNurse, Main']
  last_login_at   dateTime
  created_at      dateTime
  updated_at      dateTime
  clerk_image_url url
  department_id   string    [ref: > Departments.id]
}

Table Roles {
  id          string    [pk]
  name        string    [not null, note: 'unique']
  description string
  created_at  dateTime
}

Table Permissions {
  id          string    [pk]
  key         string    [not null, note: 'unique']
  label       string    [not null]
  category    enum      [not null, note: 'Referrals, Clinical, Reports, Settings, Division Access, Patients, Authorization, Tasks, Documents, Notes, Conflicts, Scheduling, Directory, Administration']
  created_at  dateTime
  description string
  sort_order  integer
}

Table RolePermissions {
  id            string    [pk]
  role_id       enum      [ref: > Roles.id, not null]
  permission_id enum      [ref: > Permissions.id, not null]
  allowed       string
}

Table UserPermissionOverrides {
  id            string    [pk]
  user_id       string    [ref: > Users.id, not null]
  permission_id string    [ref: > Permissions.id]
  allowed       string
}

Table PermissionPresets {
  id          string    [pk]
  name        string    [not null, note: 'unique']
  description string
  permissions text      [not null, note: 'JSON array of permission keys']
  is_system   checkbox
  created_at  string
  updated_at  string
}

Table UserPermissions {
  id                string    [pk]
  user_id           string    [ref: > Users.id, not null, note: 'unique — one per user']
  permissions       text      [not null, note: 'JSON array of permission keys']
  last_preset_id    string    [ref: > PermissionPresets.id]
  updated_at        string
  updated_by        string    [ref: > Users.id]
  allowed_assignees text      [note: 'JSON array of user IDs']
}

// ─── Departments ────────────────────────────────────────────────────────────

Table Departments {
  id                  string    [pk]
  name                string    [not null]
  supervisor          string    [ref: > Users.id]
  division            string
  department_scope_id string    [ref: > DepartmentScopes.id]
}

Table DepartmentScopes {
  id           string    [pk]
  name         string    [not null]
  stage_access multiselect [note: 'Lead Entry, Intake, Eligibility Verification, Disenrollment Required, F2F/MD Orders Pending, Clinical Intake RN Review, Authorization Pending, Conflict, Staffing Feasibility, Admin Confirmation, Pre-SOC, SOC Scheduled, SOC Completed, Hold, NTUC, OPWDD Pending']
}

// ─── Preferences & Audit ────────────────────────────────────────────────────

Table UserPreferences {
  clerk_user_id        string    [pk, note: 'matches Users.clerk_user_id']
  subnav_enabled       checkbox
  pinned_pages         text      [note: 'JSON array of page slugs']
  split_screen_enabled checkbox
  dashboard_mode       string    [note: 'executive or caseload']
}

Table ActivityLog {
  id          string    [pk]
  actor_id    enum      [ref: > Users.id, not null]
  patient_id  enum      [ref: > Patients.id]
  referral_id enum      [ref: > Referrals.id]
  action      enum      [not null, note: 'Referral Created, Stage Change, Note Added, Task Created, Patient Created, File Uploaded, Insurance Check, Conflict Flagged, Triage Submitted, Conflict Resolved, Task Completed, Hold Placed, NTUC Recorded']
  detail      string
  metadata    string    [note: 'JSON']
  timestamp   dateTime
}

// ─── Calls ──────────────────────────────────────────────────────────────────

Table Calls {
  call_id            string    [pk]
  caller_usr_id      string    [ref: > Users.id]
  related_patient_id string    [ref: > Patients.id]
  conflict_id        string    [ref: > Conflicts.id]
  date_of_call       createdTime
  topic              enum      [note: 'General Follow-up, Other']
  call_answered      string
  call_description   string
}
